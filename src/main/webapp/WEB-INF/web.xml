<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee                              https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <!-- ── Listeners ─────────────────────────────────────────────────────── -->
    <filter>
        <filter-name>IsLoginFilter</filter-name>
        <filter-class>com.mycompany.twilio.IsLoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>IsLoginFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <listener>
        <description>Opens the shared DB connection on startup</description>
        <listener-class>com.mycompany.twilio.DBConnectionInitializer</listener-class>
    </listener>
    <!-- ── Existing servlets (unchanged) ─────────────────────────────────── -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.VerifyServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>OTPgenerationServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.OTPgenerationServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResendOTPServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.ResendOTPServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>InboundSMSWebhookServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.InboundSMSWebhookServlet</servlet-class>
    </servlet>
    <!-- ── New admin servlets ────────────────────────────────────────────── -->
    <servlet>
        <servlet-name>AddCustomerServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.AddCustomerServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditCustomerServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.EditCustomerServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeleteCustomerServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.DeleteCustomerServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ListCustomersServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.ListCustomersServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CustomerStatsServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.CustomerStatsServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SendSMSServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.SendSMSServlet</servlet-class>
    </servlet>
    <!-- ── Existing servlet mappings (unchanged) ─────────────────────────── -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.ProfileServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.HomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SmsSearchServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.SmsSearchServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SmsDeleteServlet</servlet-name>
        <servlet-class>com.mycompany.twilio.SmsDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SendSMSServlet</servlet-name>
        <url-pattern>/SendSMSServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VerifyServlet</servlet-name>
        <url-pattern>/VerifyServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>OTPgenerationServlet</servlet-name>
        <url-pattern>/OTPgenerationServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResendOTPServlet</servlet-name>
        <url-pattern>/ResendOTPServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>InboundSMSWebhookServlet</servlet-name>
        <url-pattern>/InboundSMSWebhookServlet</url-pattern>
    </servlet-mapping>
    <!-- ── New admin servlet mappings ────────────────────────────────────── -->
    <servlet-mapping>
        <servlet-name>AddCustomerServlet</servlet-name>
        <url-pattern>/AddCustomerServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditCustomerServlet</servlet-name>
        <url-pattern>/EditCustomerServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteCustomerServlet</servlet-name>
        <url-pattern>/DeleteCustomerServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ListCustomersServlet</servlet-name>
        <url-pattern>/ListCustomersServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CustomerStatsServlet</servlet-name>
        <url-pattern>/CustomerStatsServlet</url-pattern>
    </servlet-mapping>
    <!-- ── Session timeout (30 minutes, same as before) ─────────────────── -->
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/ProfileServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/HomeServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SmsSearchServlet</servlet-name>
        <url-pattern>/SmsSearchServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SmsDeleteServlet</servlet-name>
        <url-pattern>/SmsDeleteServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
